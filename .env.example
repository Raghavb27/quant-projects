# ─────────────────────────────────────────────────────────────────────────────
# AlgoTrader Pro — Environment Variables
# Copy this file to .env and fill in your credentials.
# The app works in DEMO MODE without any credentials (yfinance + simulated P&L).
# ─────────────────────────────────────────────────────────────────────────────

# ── Alpaca Paper Trading (FREE) ───────────────────────────────────────────────
# Sign up at https://alpaca.markets — "Paper Trading" is completely free.
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here

# Paper trading endpoint (default). Change to live URL only when ready.
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ── Optional Override ─────────────────────────────────────────────────────────
# INITIAL_CAPITAL=100000
